# Dockerfile.prod
FROM golang:1.23-alpine AS builder

WORKDIR /app

# Copy dependencies
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY . .

# Build for production
RUN CGO_ENABLED=0 GOOS=linux go build -o ecosystem .

# Final stage
FROM alpine:latest

RUN apk --no-cache add ca-certificates

WORKDIR /root/

# Copy binary
COPY --from=builder /app/ecosystem .
COPY --from=builder /app/.env.example .env  # Optional

EXPOSE 3030

CMD ["./ecosystem"]